{
  "name": "cypress-testing",
  "version": "1.0.0",
  "description": "Integration testing for Glific using Cypress",
  "main": "index.js",
  "repository": "git@github.com:glific/cypress-testing.git",
  "author": "Kurund Jalmi <kurund.jalmi@webaccessglobal.com>",
  "dependencies": {
    "cypress": "^15.15.0",
    "cypress-split": "^1.24.28",
    "dayjs": "^1.11.10",
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^6.4.1",
    "globals": "^17.6.0",
    "prettier": "^2.8.2",
    "typescript-eslint": "^8.60.0"
  },
  "scripts": {
    "cy:run": "cypress run",
    "typecheck": "tsc --noEmit -p cypress/tsconfig.json",
    "lint": "eslint cypress",
    "lint:fix": "eslint cypress --fix",
    "format:check": "prettier --check \"cypress/**/*.{ts,js}\" \".github/**/*.{yml,yaml}\" \"*.{json,md}\" \"eslint.config.mjs\" \".prettierrc\"",
    "format": "prettier --write \"cypress/**/*.{ts,js}\" \".github/**/*.{yml,yaml}\" \"*.{json,md}\" \"eslint.config.mjs\" \".prettierrc\"",
    "verify": "bash scripts/pre-push/verify.sh"
  }
}
