  // Machine 2: Contact Import + Notification + Staff Chat
  [
    'cypress/e2e/contactImport/ContactImport.spec.ts',
    'cypress/e2e/notification/notification.spec.ts',
    'cypress/e2e/roles/staff/chat/Chat.spec.ts',
    'cypress/e2e/roles/staff/chat/ChatCollection.spec.ts',
    'cypress/e2e/roles/staff/chat/Search.spec.ts',
