    'cypress/e2e/roles/staff/contactBar/ContactBar.spec.ts',
    'cypress/e2e/collection/Collection.spec.ts',
    'cypress/e2e/staffmanagement/StaffManagement.spec.ts',
    'cypress/e2e/template/HSMTemplate.spec.ts',
    'cypress/e2e/auth/Login.spec.ts',
    'cypress/e2e/auth/Logout.spec.ts',
  ],
  // Machine 1: Settings + Simulator + Chat
  [
    'cypress/e2e/setting/FlowSetting.spec.ts',
    'cypress/e2e/simulator/Simulator.spec.ts',
    'cypress/e2e/setting/OrganizationSetting.spec.ts',
    'cypress/e2e/setting/OtherSetting.spec.ts',
    'cypress/e2e/chat/Chat.spec.ts',
    'cypress/e2e/chat/Search.spec.ts',
