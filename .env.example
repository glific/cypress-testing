# Copy this file to .env and fill in real values.
# .env is git-ignored and must never be committed.

# ── WhatsApp Web (wwebjs smoke runner) ──────────────────────────────────────

# E.164 phone number of the bot that the smoke runner will message.
# Required. Example: +910000000000
BOT_PHONE_NUMBER=

# Session ID used by whatsapp-web.js to persist the WhatsApp auth state.
# Defaults to "production-sender" or "staging-sender" when not set.
WHATSAPP_SESSION_ID=

# ── Google Cloud Storage ─────────────────────────────────────────────────────

# GCS bucket name where whatsapp-web.js session files are stored.
GCS_BUCKET=

# Path to the GCP service-account JSON key file (for local runs).
# In CI, use Workload Identity or set GOOGLE_APPLICATION_CREDENTIALS instead.
GCP_SA_KEY_JSON=

# ── Instatus ─────────────────────────────────────────────────────────────────

# API key for posting smoke-test results to the Instatus status page.
INSTATUS_API_KEY=

# Instatus status-page ID (find it in your Instatus dashboard URL).
INSTATUS_PAGE_ID=

# Instatus component ID to update on pass / fail.
INSTATUS_COMPONENT_ID=

# ── Cypress E2E ──────────────────────────────────────────────────────────────

# Full URL of the Glific chat page used by Cypress smoke tests.
# Example: https://glific.example.org/chat/1234567890
CYPRESS_SMOKE_TEST_CHAT_URL=

# Phone number and password for the Glific account Cypress logs in with.
CYPRESS_SMOKE_TEST_LOGIN_PHONE_NUMBER=
CYPRESS_SMOKE_TEST_LOGIN_PASSWORD=

# Instatus credentials forwarded to Cypress (mirrors the values above).
CYPRESS_INSTATUS_API_KEY=
CYPRESS_INSTATUS_PAGE_ID=
CYPRESS_INSTATUS_COMPONENT_ID=

# ── Kaapi ────────────────────────────────────────────────────────────────────

# API key for the Kaapi integration.
KAAPI_API_KEY=
